# ── JWT / Auth ────────────────────────────────────────────────────────────────
# A long random string used to sign JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string

# ── Database (Turso / libSQL) ─────────────────────────────────────────────────
# Leave blank to use a local SQLite file (local.db) in development.
# On Vercel, set both of these so data persists across serverless invocations.
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── OAuth — Google ────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI to add:
#   Vercel production: https://your-app.vercel.app/auth/google/callback
#   Local dev:         http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── OAuth — Facebook ──────────────────────────────────────────────────────────
# Create an app at https://developers.facebook.com/apps
# Valid OAuth Redirect URI to add:
#   Vercel production: https://your-app.vercel.app/auth/facebook/callback
#   Local dev:         http://localhost:5000/auth/facebook/callback
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ── App URL (Vercel) ──────────────────────────────────────────────────────────
# Set this on Vercel so OAuth callbacks use the right domain.
# Example: https://your-app.vercel.app
# If you have a custom domain: https://yourdomain.com
APP_URL=https://your-app.vercel.app
